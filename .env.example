# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here

# Database
DATABASE_URL=sqlite+aiosqlite:///bot.db

# Bot Configuration
OWNER_ID=your_discord_user_id
LOG_LEVEL=INFO

# Web Dashboard Configuration
ENABLE_DASHBOARD=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change_this_to_random_secret_key

# Roblox Integration (Optional - for real game stats)
ROBLOX_API_KEY=your_roblox_open_cloud_api_key_here
ROBLOX_UNIVERSE_ID=your_universe_id_here
ROBLOX_PLACE_ID=your_place_id_here
ROBLOX_WEBHOOK_SECRET=your_webhook_secret_here

# Dashboard URL (for /web command)
DASHBOARD_URL=http://localhost:5000

# Discord OAuth2 (for public bot invite page at /invite)
DISCORD_CLIENT_ID=your_discord_application_client_id

# Note: Translation and YouTube features now use FREE services!
# - Translation: Uses free googletrans library (no API key needed)
# - YouTube: Uses free RSS feeds (no API key needed)
